# Copy to .env and fill in secrets. NEVER commit .env.
# Every value below is read by src/fraud_engine/config/settings.py.

# --- reproducibility ---
SEED=42

# --- logging ---
# stdlib log level — one of DEBUG|INFO|WARNING|ERROR|CRITICAL. DEBUG
# emits feature values and may expose PII, so keep it out of prod.
LOG_LEVEL=INFO

# --- paths (relative to repo root; see Settings.ensure_directories) ---
# Root for raw/interim/processed data. Gitignored.
DATA_DIR=./data
# Persisted model artefacts (joblib/pt/pkl). Gitignored.
MODELS_DIR=./models
# Pipeline log directory — {pipeline_name}/{run_id}.log. Gitignored.
LOGS_DIR=./logs

# --- data provider credentials (Sprint 1 will use these) ---
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-api-key

# --- infrastructure ---
REDIS_URL=redis://localhost:6379/0
POSTGRES_URL=postgresql://fraud:fraud@localhost:5432/fraud
MLFLOW_TRACKING_URI=./mlruns
# MLflow experiment name. Every training run and threshold sweep opens
# under this experiment so model selection lives in a single tree.
MLFLOW_EXPERIMENT_NAME=fraud-detection
# Postgres bootstrap credentials used by docker-compose.dev.yml to
# initialise the fraud-postgres container. `fraud/fraud/fraud` is the
# dev-only default; production deployments must override. POSTGRES_URL
# above must reference the same user / database.
POSTGRES_USER=fraud
POSTGRES_PASSWORD=fraud
POSTGRES_DB=fraud
# Host ports published by docker-compose.dev.yml. Change if a port
# collides on your machine — no other code reads the port.
POSTGRES_PORT=5432
REDIS_PORT=6379
MLFLOW_PORT=5000
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
# Grafana admin seed. `admin/admin` is dev-only; Grafana forces a
# password change on first login in prod-grade deployments.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- economic costs for expected-cost thresholding (Sprint 4) ---
# Mean marginal cost of a missed fraud (USD). Calibrated from 2024 industry
# data on median fraud loss per approved transaction in card-not-present flows.
FRAUD_COST_USD=450
# Customer-friction cost of a false alert (USD). Covers support contact,
# re-auth friction, and downstream churn probability.
FP_COST_USD=35
# Operational cost of a verified true positive (USD) — analyst review time.
TP_COST_USD=5
# Decision threshold. Overwritten after Sprint 4 cost-curve optimization.
DECISION_THRESHOLD=0.5

# --- temporal split (Sprint 1) ---
# Community-standard calendar anchor for IEEE-CIS TransactionDT=0. This
# is a convention — Kaggle does not publish the true anchor. Override
# only if a future Kaggle release changes the reference.
TRANSACTION_DT_ANCHOR_ISO=2017-12-01T00:00:00+00:00
# Train/val boundaries in TransactionDT seconds since the anchor.
# Defaults encode a 4/1/1 calendar-month split: train=Dec 2017..Mar
# 2018 (121 days), val=Apr 2018 (+30 days), test=May 2018 onwards.
TRAIN_END_DT=10454400
VAL_END_DT=13046400
