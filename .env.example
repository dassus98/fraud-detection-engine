# Copy to .env and fill in secrets. NEVER commit .env.
# Every value below is read by src/fraud_engine/config/settings.py.

# --- reproducibility ---
SEED=42

# --- logging ---
LOG_LEVEL=INFO

# --- paths (relative to repo root; see Settings.ensure_directories) ---
DATA_DIR=./data

# --- data provider credentials (Sprint 1 will use these) ---
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-api-key

# --- infrastructure ---
REDIS_URL=redis://localhost:6379/0
POSTGRES_URL=postgresql://fraud:fraud@localhost:5432/fraud
MLFLOW_TRACKING_URI=./mlruns

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- economic costs for expected-cost thresholding (Sprint 4) ---
# Mean marginal cost of a missed fraud (USD). Calibrated from 2024 industry
# data on median fraud loss per approved transaction in card-not-present flows.
FRAUD_COST_USD=450
# Customer-friction cost of a false alert (USD). Covers support contact,
# re-auth friction, and downstream churn probability.
FP_COST_USD=35
# Operational cost of a verified true positive (USD) — analyst review time.
TP_COST_USD=5
# Decision threshold. Overwritten after Sprint 4 cost-curve optimization.
DECISION_THRESHOLD=0.5
