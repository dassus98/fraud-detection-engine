# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
build/
dist/
.eggs/
wheels/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/

# Environment variables
.env
.env.*
!.env.example

# Kaggle credentials (JSON format). Mirror of .env creds in Kaggle's
# native kaggle.json format; never commit either representation.
kaggle.json
.kaggle/

# Data and runtime artifacts (anchored to repo root so src/fraud_engine/data/
# and src/fraud_engine/models/ packages are NOT ignored).
# Uses the /data/* + !/data/raw/ + /data/raw/* + !/data/raw/MANIFEST.json
# pattern so MANIFEST.json survives the ignore while every CSV under
# data/raw/ is still ignored. Parent-dir traversal requires the negations.
/data/*
!/data/raw/
/data/raw/*
!/data/raw/MANIFEST.json
/logs/
/models/
/mlruns/
/reports/
*.joblib
*.pkl
*.pt

# Tool caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyright/
.ipynb_checkpoints/
.coverage
coverage.xml
htmlcov/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Secrets baseline generated by detect-secrets (kept, baseline file itself is committed)
# .secrets.baseline is committed so pre-commit can diff against it.
